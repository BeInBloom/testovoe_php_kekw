{
  "name": "testovoe/news-site",
  "description": "Mini news site without frameworks",
  "license": "proprietary",
  "type": "project",
  "require": {
    "php": "^8.3",
    "php-di/php-di": "^7.0",
    "monolog/monolog": "^3.5",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "phpstan/phpstan": "^1.10",
    "phpstan/extension-installer": "^1.4",
    "friendsofphp/php-cs-fixer": "^3.45",
    "squizlabs/php_codesniffer": "^3.9"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:coverage": "php -r \"if (!extension_loaded('xdebug') && !extension_loaded('pcov')) {fwrite(STDERR, 'Coverage driver is not enabled. Enable xdebug or pcov (see README).'.PHP_EOL); exit(1);} \" && XDEBUG_MODE=coverage phpunit --coverage-text",
    "analyse": "phpstan analyse --memory-limit=512M --no-progress --debug",
    "cs-fix": "PHP_CS_FIXER_IGNORE_ENV=1 php-cs-fixer fix --config php-cs-fixer.php",
    "cs-check": "PHP_CS_FIXER_IGNORE_ENV=1 php-cs-fixer fix --config php-cs-fixer.php --dry-run --diff"
  },
  "config": {
    "allow-plugins": {
      "phpstan/extension-installer": true
    },
    "sort-packages": true
  }
}
